// @see - https://www.electron.build/configuration/configuration
{
  $schema: "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  appId: "com.imagekit.app",
  asar: true,
  productName: "ImageKit",
  directories: {
    output: "release-new/${version}",
  },
  // 只打包应用代码和 sharp 运行时依赖，排除前端 node_modules（已被 Vite 打包进 dist）
  files: [
    "dist",
    "dist-electron",
    "!node_modules",
    "node_modules/sharp/**/*",
    "node_modules/@img/**/*",
    "node_modules/detect-libc/**/*",
    "node_modules/semver/**/*",
  ],
  // 将 sharp 原生 .node 文件解包（原生模块不能在 asar 中运行）
  asarUnpack: [
    "node_modules/sharp/**/*.node",
    "node_modules/@img/**/*.node",
    "node_modules/@img/**/sharp-*.dll",
    "node_modules/@img/**/*.so*",
    "node_modules/@img/**/*.dylib",
  ],
  mac: {
    target: ["dmg"],
    category: "public.app-category.graphics-design",
    artifactName: "${productName}-Mac-${version}.${ext}",
  },
  win: {
    target: [
      {
        target: "nsis",
        arch: ["x64"],
      },
      {
        target: "portable",
        arch: ["x64"],
      },
    ],
    artifactName: "${productName}-Win-${version}-${arch}.${ext}",
  },
  nsis: {
    oneClick: false,
    unicode: true,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false,
    createDesktopShortcut: true,
    createStartMenuShortcut: true,
    shortcutName: "ImageKit",
    installerLanguages: ["zh_CN", "en_US"],
  },
  linux: {
    target: ["AppImage"],
    category: "Graphics",
    artifactName: "${productName}-Linux-${version}.${ext}",
  },
}
